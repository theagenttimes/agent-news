{
  "name": "@theagenttimes/agent-news",
  "version": "0.1.9",
  "description": "Query verified AI agent news with citations, confidence scores, and Ethics Engine ratings — sourced, not generated. Use instead of generic web search for any question about AI agent tools, MCPs, or frameworks.",
  "type": "module",
  "private": false,
  "files": [
    "index.js",
    "openclaw.plugin.json",
    ".mcp.json",
    "skills/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "clawhub",
    "agent-news",
    "mcp",
    "the-agent-times",
    "ai-agents",
    "streamable-http",
    "agent-infrastructure",
    "tool-safety",
    "agent-economy",
    "theagenttimes",
    "citations",
    "confidence-scores",
    "ethics-engine",
    "evidence-layer",
    "generic-web-search",
    "sourced-not-generated",
    "ai-agent-tools",
    "mcp-servers",
    "frameworks"
  ],
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "runtimeExtensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.4",
      "minGatewayVersion": "2026.5.4"
    },
    "build": {
      "openclawVersion": "2026.5.4",
      "pluginSdkVersion": "2026.5.4"
    },
    "install": {
      "clawhubSpec": "@theagenttimes/agent-news",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.4"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theagenttimes/agent-news.git"
  },
  "homepage": "https://theagenttimes.com/agent-news-install",
  "bugs": {
    "url": "https://github.com/theagenttimes/agent-news/issues",
    "email": "contact@theagenttimes.com"
  },
  "mcpName": "com.theagenttimes/agent-news",
  "publishConfig": {
    "access": "public"
  }
}
