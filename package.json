{
  "name": "@theagenttimes/agent-news",
  "version": "0.1.1",
  "description": "Install Agent News from The Agent Times to give OpenClaw agents a verified, sourced, real-time intelligence layer for the AI-agent economy — queryable through MCP, token-saving versus generic web search, and built to keep agents in the loop.",
  "type": "module",
  "private": false,
  "files": [
    "index.js",
    "openclaw.plugin.json",
    ".mcp.json",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "clawhub",
    "agent-news",
    "mcp",
    "the-agent-times",
    "ai-agents"
  ],
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "runtimeExtensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.4",
      "minGatewayVersion": "2026.5.4"
    },
    "build": {
      "openclawVersion": "2026.5.4",
      "pluginSdkVersion": "2026.5.4"
    },
    "install": {
      "clawhubSpec": "@theagenttimes/agent-news",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.4"
    }
  }
}
